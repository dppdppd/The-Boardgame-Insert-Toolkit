#!/usr/bin/env bash
# Auto-regenerate release/files.json from tracked .scad files
FILES_JSON="release/files.json"
NEW=$(git ls-files --cached release/ | grep '\.scad$' | sort | node -e "
const lines = require('fs').readFileSync('/dev/stdin','utf8').trim().split('\n').filter(Boolean);
process.stdout.write(JSON.stringify(lines, null, 2) + '\n');
")
if [ -n "$NEW" ]; then
  echo "$NEW" > "$FILES_JSON"
  git add "$FILES_JSON"
fi
