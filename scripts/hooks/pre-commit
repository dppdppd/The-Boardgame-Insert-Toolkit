#!/usr/bin/env bash
# Stamp VERSION into the v4 lib based on commit count since the v4.0.0 tag.
# version = "4.0.<N>" where N = (commits since v4.0.0) + 1, accounting for
# the in-progress commit that hasn't landed yet.
#
# Activate by running ./scripts/install-hooks.sh once per clone (sets
# git config core.hooksPath = scripts/hooks).
set -e

LIB="release/lib/boardgame_insert_toolkit_lib.4.scad"
BASELINE="v4.0.0"

# Skip silently if the lib file isn't present (rebase, partial checkout, etc).
[ -f "$LIB" ] || exit 0

# Skip silently if the baseline tag is missing — operator may be on an older
# branch or doing surgery; don't block the commit.
git rev-parse "$BASELINE" >/dev/null 2>&1 || {
    echo "pre-commit: tag $BASELINE not found, skipping VERSION stamp" >&2
    exit 0
}

COUNT=$(git rev-list --count "${BASELINE}..HEAD" 2>/dev/null || echo 0)
NEW_PATCH=$((COUNT + 1))
NEW_VERSION="4.0.${NEW_PATCH}"

# Idempotent rewrite: -i.bak works on both GNU and BSD sed; the .bak file is
# removed afterward.
sed -i.bak "s/^VERSION = \"[^\"]*\";/VERSION = \"${NEW_VERSION}\";/" "$LIB"
sed -i.bak "s|^ \* Version: .*| * Version: ${NEW_VERSION}|" "$LIB"
rm -f "${LIB}.bak"

# Stage the (possibly no-op) version edit so it rides along with the commit.
git add "$LIB"
