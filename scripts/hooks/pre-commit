#!/usr/bin/env bash
# Stamp VERSION into the v4 lib.
#
# Default behavior increments patch. Set BIT_VERSION_BUMP=minor for
# user-facing feature releases.
#
# Activate by running ./scripts/install-hooks.sh once per clone (sets
# git config core.hooksPath = scripts/hooks).
set -e

LIB="release/lib/boardgame_insert_toolkit_lib.4.scad"
BUMP="${BIT_VERSION_BUMP:-patch}"

. "$(git rev-parse --show-toplevel)/scripts/version-common.sh"

# Skip silently if the lib file isn't present (rebase, partial checkout, etc).
[ -f "$LIB" ] || exit 0

CURRENT_VERSION="$(bit_current_version "$LIB")"
if bit_versioned_lib_matches "$CURRENT_VERSION" "$LIB"; then
    NEW_VERSION="$CURRENT_VERSION"
else
    NEW_VERSION="$(bit_next_version "$BUMP" "$CURRENT_VERSION")"
fi

bit_stamp_version "$NEW_VERSION" "$LIB"

# Stage the (possibly no-op) version edit so it rides along with the commit.
git add "$LIB"
